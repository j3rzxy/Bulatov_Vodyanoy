<Page x:Class="_223_Bulatov_Vodyanoy.Pages.Func3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_223_Bulatov_Vodyanoy.Pages"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Func3">

    <Grid Background="White">
        <TextBox x:Name="TBX" ToolTip="Введите переменную x" HorizontalAlignment="Left" Margin="310,156,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70"/>
        <TextBox x:Name="TBX0" ToolTip="Введите левую границу x0" HorizontalAlignment="Left" Margin="310,248,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70"/>
        <TextBox x:Name="TBXk" ToolTip="Введите правую границу xk" HorizontalAlignment="Left" Margin="310,202,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70"/>
        <TextBox x:Name="TBdX" ToolTip="Введите шаг dx" HorizontalAlignment="Left" Margin="310,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70"/>
        <TextBox x:Name="TBB" ToolTip="Введите переменную b" HorizontalAlignment="Left" Margin="310,179,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70"/>
        <TextBox x:Name="TBResult" ToolTip="Значения функции при заданных параметрах" HorizontalAlignment="Left" Margin="310,271,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="70" IsReadOnly="True" Height="80"/>
        <Label Content="x" HorizontalAlignment="Left" Margin="294,152,0,0" VerticalAlignment="Top"/>
        <Label Content="x0" HorizontalAlignment="Left" Margin="287,175,0,0" VerticalAlignment="Top"/>
        <Label Content="xk" HorizontalAlignment="Left" Margin="287,198,0,0" VerticalAlignment="Top"/>
        <Label Content="dx" HorizontalAlignment="Left" Margin="286,221,0,0" VerticalAlignment="Top"/>
        <Label Content="b" HorizontalAlignment="Left" Margin="292,244,0,0" VerticalAlignment="Top"/>
        <Label Content="Ответ" HorizontalAlignment="Left" Margin="268,276,0,0" VerticalAlignment="Top" Height="30"/>
        <Button Content="Очистить" ToolTip="Очистить все текстовые поля с данными" HorizontalAlignment="Left" Margin="310,406,0,0" VerticalAlignment="Top" Height="26" Width="70" Click="Clear_Click"/>
        <Button Content="Вычислить" ToolTip="Вычислить выражение на основе введеных параметров" HorizontalAlignment="Left" Margin="310,375,0,0" VerticalAlignment="Top" Height="26" Width="70" Click="Count_Click"/>
        <Image Margin="297,84,226,310" Source="/Image1.png" Stretch="Fill"/>
        <WindowsFormsHost x:Name="chartHost" HorizontalAlignment="Left" Height="180" Margin="400,156,0,0" VerticalAlignment="Top" Width="180">

        </WindowsFormsHost>
    </Grid>
</Page>

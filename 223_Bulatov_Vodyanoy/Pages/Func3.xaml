        <WindowsFormsHost HorizontalAlignment="Left" Height="185" Margin="400,207,0,0" VerticalAlignment="Top" Width="185">
            <charts:Chart x:Name="ChartPayments">
                <charts:Chart.Legends>
                    <charts:Legend>

                    </charts:Legend>
                </charts:Chart.Legends>

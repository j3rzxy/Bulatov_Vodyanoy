<Page x:Class="_223_Bulatov_Vodyanoy.Pages.Func1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_223_Bulatov_Vodyanoy.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Func1">

    <Grid Background="White">
        <Image Margin="131,103,195,242" Source="/Аннотация 2026-02-24 094352.png" Stretch="Fill"/>
        <TextBox x:Name="TBX" ToolTip="Введите переменную x" HorizontalAlignment="Left" Margin="284,217,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90"/>
        <TextBox x:Name="TBY" ToolTip="Введите переменную y" HorizontalAlignment="Left" Margin="284,240,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90"/>
        <TextBox x:Name="TBZ" ToolTip="Введите переменную z" HorizontalAlignment="Left" Margin="284,263,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90"/>
        <TextBox x:Name="TBResult" ToolTip="Результат вычислений" HorizontalAlignment="Left" Margin="284,286,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90" IsReadOnly="True"/>
        <Label Content="x" HorizontalAlignment="Left" Margin="263,213,0,0" VerticalAlignment="Top"/>
        <Label Content="y" HorizontalAlignment="Left" Margin="263,236,0,0" VerticalAlignment="Top"/>
        <Label Content="z" HorizontalAlignment="Left" Margin="263,259,0,0" VerticalAlignment="Top"/>
        <Label Content="Ответ" HorizontalAlignment="Left" Margin="237,280,0,0" VerticalAlignment="Top" Height="30"/>
        <Button Content="Очистить" ToolTip="Очистить все текстовые поля с данными" HorizontalAlignment="Left" Margin="393,282,0,0" VerticalAlignment="Top" Height="26" Width="70" Click="Clear_Click"/>
        <Button Content="Вычислить" ToolTip="Вычислить выражение на основе введеных параметров" HorizontalAlignment="Left" Margin="393,213,0,0" VerticalAlignment="Top" Height="26" Width="70" Click="Count_Click"/>
    </Grid>
</Page>
